# ============================================================
# KANIDA.AI Terminal — Quant Intelligence Engine
# Environment Configuration Template
# Copy this to .env and fill in your values. NEVER commit .env.
# ============================================================

# ── Claude AI ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# ── Zerodha Kite Connect (NSE + F&O) ───────────────────────
# Get from: kite.trade/account/apps
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_ACCESS_TOKEN=             # Set daily after login (refresh via auth flow)

# ── Polygon.io (US Equities + Options) ─────────────────────
# Get from: polygon.io/dashboard/api-keys
POLYGON_API_KEY=your_polygon_api_key

# ── Database ───────────────────────────────────────────────
# Path to the single source-of-truth DB (relative to project root)
KANIDA_DB_PATH=data/db/kanida_quant.db

# ── Server ─────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000

# ── Market Settings ────────────────────────────────────────
NSE_MARKET_OPEN_IST=09:15
NSE_MARKET_CLOSE_IST=15:30
US_MARKET_OPEN_ET=09:30
US_MARKET_CLOSE_ET=16:00

# ── Compliance Mode ────────────────────────────────────────
# SEBI_SAFE  → statistical framing only (use for India-facing product)
# GLOBAL     → direct signal language
COMPLIANCE_MODE=SEBI_SAFE

# ── Data Quality ───────────────────────────────────────────
# Reject any day where single-day move exceeds this threshold on low volume
DATA_QUALITY_MAX_MOVE_PCT=0.12
DATA_QUALITY_MIN_VOLUME_RATIO=0.30  # vs 30-day avg
